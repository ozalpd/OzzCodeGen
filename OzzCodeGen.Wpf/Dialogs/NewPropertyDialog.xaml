<Window x:Class="OzzCodeGen.Wpf.Dialogs.NewPropertyDialog" Name="window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Property" Height="400" Width="460" ShowInTaskbar="False" Loaded="window_Loaded">

    <Grid DataContext="{Binding ElementName=window, Mode=OneWay}" Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="48"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" DataContext="{Binding PropertyDefinition}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="26"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="80"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Property Name:" Margin="5"/>
            <TextBox Name="txtPropertyName"
                     Text="{Binding Name}" 
                     Margin="1" Grid.Row="0" Grid.Column="1" 
                     Grid.ColumnSpan="3"
                     HorizontalAlignment="Stretch" 
                     TabIndex="0"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Property Type:" Margin="5"/>
            <ComboBox ItemsSource="{Binding UsableTypeNames}"
                      Text="{Binding TypeName}" 
                      Grid.Row="1" Grid.Column="1" Margin="1" 
                      Grid.ColumnSpan="2"
                      TabIndex="1"/>
            <Button Name="btnPropertyName" Content="Set Property Name" ToolTip="Set Property Name same as Property Type"
                    Grid.Row="1" Grid.Column="3" Margin="1" 
                    TabIndex="2" Click="btnPropertyName_Click" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Comment:" Margin="5"/>
            <TextBox Text="{Binding Comment}" 
                     Grid.Row="3" Grid.Column="1" Margin="1" 
                     Grid.ColumnSpan="3"
                     HorizontalAlignment="Stretch" 
                     TextWrapping="Wrap" 
                     TabIndex="8"/>
        </Grid>
        <Grid x:Name="SimplePropertySettingsContainer" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="26"/>
                <RowDefinition Height="26"/>
                <RowDefinition Height="26"/>
                <RowDefinition Height="6"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Server Computed:" Margin="5"/>
            <CheckBox Grid.Row="0" Grid.Column="1" IsChecked="{Binding IsServerComputed}" VerticalAlignment="Center" TabIndex="3"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="Store Generated:" Margin="5"/>
            <CheckBox Grid.Row="0" Grid.Column="3" IsChecked="{Binding IsStoreGenerated}" VerticalAlignment="Center" TabIndex="4"/>
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Client Computed:" Margin="5"/>
            <CheckBox Grid.Row="1" Grid.Column="1" IsChecked="{Binding IsClientComputed}" VerticalAlignment="Center" TabIndex="5"/>


            <TextBlock Grid.Row="2" Grid.Column="0" Text="Nullable:" Margin="5"/>
            <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding IsNullable}" VerticalAlignment="Center" TabIndex="6"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="Immutable:" Margin="5"/>
            <CheckBox Grid.Row="2" Grid.Column="3" IsChecked="{Binding IsImmutable}" VerticalAlignment="Center" TabIndex="7"/>

            <!--
            <TextBlock Text="Max Length:" Grid.Row="3" Grid.Column="0"/>
            <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding MaxLength, Mode=TwoWay, NotifyOnValidationError=True}"/>
            -->
        </Grid>

        <Grid Name="ComplexPropertySettingsContainer" Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="26"/>
                <RowDefinition Height="26"/>
                <RowDefinition Height="26"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Create Dependecy:" 
                       ToolTip="Create Dependecy Property"
                       Grid.Row="0" Grid.Column="0" Margin="5"/>
            <CheckBox IsChecked="{Binding CreateDependecy}" 
                      Grid.Row="0" Grid.Column="1" VerticalAlignment="Center" 
                      ToolTip="Create Foreign Key"
                      TabIndex="11"/>

            <TextBlock Text="Depd. Prpr. Name:" ToolTip="Dependent Property Name" Grid.Row="1" Grid.Column="0" Margin="5"/>
            <TextBox Text="{Binding DependentProperty.Name}"
                     ToolTip="Dependent Property Name"
                     Margin="1" Grid.Row="1" Grid.Column="1" 
                     Grid.ColumnSpan="3"
                     HorizontalAlignment="Stretch" 
                     TabIndex="12"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Nullable:" Margin="5"/>
            <CheckBox Grid.Row="2" Grid.Column="1" IsChecked="{Binding DependentProperty.IsNullable}" VerticalAlignment="Center" TabIndex="6"/>
            <TextBlock Grid.Row="2" Grid.Column="2" Text="Immutable:" Margin="5"/>
            <CheckBox Grid.Row="2" Grid.Column="3" IsChecked="{Binding DependentProperty.IsImmutable}" VerticalAlignment="Center" TabIndex="7"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Property Type:" Margin="5"/>
            <ComboBox ItemsSource="{Binding DependentProperty.UsableTypeNames}"
                      Text="{Binding DependentProperty.TypeName}" 
                      Grid.Row="3" Grid.Column="1" Margin="1" 
                      Grid.ColumnSpan="3"
                      TabIndex="1"/>

        </Grid>

        <Grid Name="CollectionPropertySettingsContainer" Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Dependent Entity:" Margin="5"/>
            <TextBox Text="{Binding DependentEntityName}" 
                     Margin="1" Grid.Row="0" Grid.Column="1" 
                     Grid.ColumnSpan="3"
                     IsReadOnly="True"
                     HorizontalAlignment="Stretch" 
                     TabIndex="0"/>

        </Grid>

        <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Margin="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="btnAccept" Content="OK" Width="72" Margin="5" IsDefault="True" Click="btnAccept_Click" TabIndex="121" />
            <Button Name="btnCancel" Content="Cancel" Width="72" Margin="5" IsCancel="True" TabIndex="122"/>
        </StackPanel>
    </Grid>
</Window>
