<ui:AbstractEngineUI x:Class="OzzCodeGen.CodeEngines.CsModelClass.UI.ModelClassEngineUI"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:ui="clr-namespace:OzzCodeGen.UI"
                     xmlns:local="clr-namespace:OzzCodeGen.CodeEngines.CsModelClass.UI"
                     mc:Ignorable="d" 
                     d:DesignHeight="460" d:DesignWidth="1400">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/OzzCodeGen;component/Resources/BootstrapIcons.xaml" />
                <ResourceDictionary Source="/OzzCodeGen;component/Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Border BorderBrush="#FF9090AF" Background="#FFD8E8FF" Padding="2" Margin="2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="172"/>
                <ColumnDefinition Width="172" />
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="176"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="26"/>
                <RowDefinition Height="26"/>
                <RowDefinition Height="26"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button x:Name="btnRenderTemplate"
                    Content="Render Template"
                    Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Margin="4"
                    Click="btnRenderTemplate_Click"/>

            <Button x:Name="btnRefresh"
                    Content="Refresh"
                    Grid.Column="0" Grid.Row="2" Grid.RowSpan="2" Margin="4"
                    Click="btnRefresh_Click"/>

            <CheckBox Content="All Entities"
                  IsChecked="{Binding RenderAllEntities}"
                  ToolTip="Render for every entity in the model."
                  Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0"/>

            <CheckBox Grid.Column="1" Grid.Row="1" VerticalAlignment="Center" Margin="4,0,0,0"
                  Content="Overwrite Existing Files"
                  IsChecked="{Binding OverwriteExisting}"/>

            <CheckBox Grid.Column="1" Grid.Row="2" VerticalAlignment="Center" Margin="4,0,0,0"
                      Content="Generate for DTO"
                      ToolTip="Generate metadata classes for DataTranferObjects"
                      IsChecked="{Binding GenerateForDTO}"/>

            
            <CheckBox Grid.Column="2" Grid.Row="0" VerticalAlignment="Center" Margin="0"
                      Content="Generate Annotations"
                      ToolTip="Generate annotations for the metadata classes"
                      IsChecked="{Binding GenAnnotations}"/>

            <CheckBox Grid.Column="2" Grid.Row="1" VerticalAlignment="Center" Margin="0"
                      Content="Generate Validator"
                      ToolTip="Generate a validator class for all the entities"
                      IsChecked="{Binding GenerateValidator}"/>

            <CheckBox Grid.Column="2" Grid.Row="2" VerticalAlignment="Center" Margin="0"
                      Content="Use Resx Resource"
                      ToolTip="Use resx resource files for error messages and display names instead of hard coded strings"
                      IsChecked="{Binding UseResourceFiles}"/>

            <CheckBox Grid.Column="2" Grid.Row="3" VerticalAlignment="Center" Margin="0"
                      Content="Generate XML Doc"
                      ToolTip="Generate XML documentation for the metadata classes"
                      IsChecked="{Binding GenerateXmlDoc}"/>



            <TextBlock Grid.Column="3" Grid.Row="0" Margin="4,0,0,0"
                       Text="Model Namespace:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="4" Grid.Row="0"
                     Text="{Binding NamespaceName, Mode=TwoWay}"
                     Style="{StaticResource textBoxStyle}"/>

            <TextBlock Grid.Column="3" Grid.Row="1" Margin="4,0,0,0"
                       Text="Validator Namespace:"
                       ToolTip="Namespace of Generated Validator Class"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="4" Grid.Row="1"
                     Text="{Binding ValidatorNamespaceName, Mode=TwoWay}"
                     ToolTip="Namespace of Generated Validator Class"
                     Style="{StaticResource textBoxStyle}"/>

            <TextBlock Grid.Column="3" Grid.Row="2" Margin="4,0,0,0"
                       Text="QueryParameters Namespace:"
                       ToolTip="Namespace of Generated QueryParameters Class"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="4" Grid.Row="2"
                     Text="{Binding QueryParamNamespaceName, Mode=TwoWay}"
                     ToolTip="Namespace of Generated QueryParameters Class"
                     Style="{StaticResource textBoxStyle}"/>

            <TextBlock Grid.Column="3" Grid.Row="3" Margin="4,0,0,0"
                       Text="Custom Attrib. Namespace:"
                       ToolTip="Namespace of Custom Attributes"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="4" Grid.Row="3"
                     Text="{Binding CustomAttribNamespace, Mode=TwoWay}"
                     ToolTip="Namespace of Custom Attributes"
                     Style="{StaticResource textBoxStyle}"/>


            <TextBlock Grid.Column="5" Grid.Row="0" Margin="4,0,0,0"
                       Text="Target Model Folder:"
                       ToolTip="Target folder for generated model class files"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="6" Grid.Row="0"
                     Text="{Binding TargetFolder, Mode=TwoWay}"
                     ToolTip="{Binding TargetDirectory}"
                     Style="{StaticResource textBoxStyle}"/>

            <TextBlock Text="Target Validator Folder:"
                   ToolTip="Target folder for generated validator class file"
                   Grid.Column="5" Grid.Row="1" Margin="4,0,0,0" VerticalAlignment="Center"/>
            <TextBox Grid.Column="6" Grid.Row="1"
                     Text="{Binding ValidatorFolder, Mode=TwoWay}"
                     ToolTip="{Binding TargetValidatorDirectory}"
                     Style="{StaticResource textBoxStyle}"/>

            <TextBlock Text="Target QueryParameters Folder:"
                   ToolTip="Target folder for generated QueryParameters class file"
                   Grid.Column="5" Grid.Row="2" Margin="4,0,0,0" VerticalAlignment="Center"/>
            <TextBox Grid.Column="6" Grid.Row="2"
                     Text="{Binding QueryParamFolder, Mode=TwoWay}"
                     ToolTip="{Binding TargetQueryParamDirectory}"
                     Style="{StaticResource textBoxStyle}"/>



            <Grid Grid.Row="4" Grid.ColumnSpan="7" Margin="4,4,4,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MaxWidth="480"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <DataGrid x:Name="grdEntitySettings" ItemsSource="{Binding Entities, Mode=TwoWay}" 
                SelectedItem="{Binding CurrentEntitySetting, Mode=TwoWay}"
                AutoGeneratedColumns="grdEntitySettings_AutoGeneratedColumns"
                CanUserDeleteRows="False" 
                CanUserAddRows="False"  
                AutoGeneratingColumn="grdEntitySettings_AutoGeneratingColumn">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="mnuEntityOptions"  Header="Options" IsEnabled="False" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>

                <GridSplitter Grid.Column="1" Grid.RowSpan="2" HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="8" ResizeDirection="Columns" />

                <Grid Grid.Column="2" Grid.Row="8" Grid.ColumnSpan="2" Margin="8,0,0,0"
                      DataContext="{Binding SelectedItem, ElementName=grdEntitySettings}">
                    <DataGrid x:Name="grdPropertySettings" Grid.Row="2"
                              ItemsSource="{Binding Properties, Mode=TwoWay}"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              AutoGeneratedColumns="grdPropertySettings_AutoGeneratedColumns"
                              AutoGeneratingColumn="grdEntitySettings_AutoGeneratingColumn">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="mnuPropertyOptions"  Header="Options" IsEnabled="False" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Data Type" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DataType}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding DataType}"
                                              ItemsSource="{Binding DataTypeList, RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type local:ModelClassEngineUI}}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Html Encode" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding HtmlEncode, TargetNullValue=Null}">
                                            <TextBlock.ToolTip>
                                                <ToolTip Content="{Binding HtmlEncode, Mode=OneWay, TargetNullValue=Null}" ContentStringFormat="Html Encode: {0}"/>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <CheckBox IsThreeState="True" IsChecked="{Binding HtmlEncode}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</ui:AbstractEngineUI>
