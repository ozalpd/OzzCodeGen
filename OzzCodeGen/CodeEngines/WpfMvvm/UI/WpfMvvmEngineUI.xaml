<ui:AbstractEngineUI x:Class="OzzCodeGen.CodeEngines.WpfMvvm.UI.WpfMvvmEngineUI"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:ui="clr-namespace:OzzCodeGen.UI"
                     mc:Ignorable="d"
                     d:DesignHeight="460" d:DesignWidth="1400">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/OzzCodeGen;component/Resources/BootstrapIcons.xaml" />
                <ResourceDictionary Source="/OzzCodeGen;component/Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border BorderBrush="#FF9090AF" Background="#FFFFE19F" Padding="2" Margin="2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="144" />
                <ColumnDefinition Width="64" />
                <ColumnDefinition Width="96" />
                <ColumnDefinition Width="96" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="26"/>
                <RowDefinition Height="26"/>
                <RowDefinition Height="26"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.RowSpan="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="26"/>
                </Grid.RowDefinitions>
                <Button x:Name="btnRenderTemplate"
                        Content="Render Template"
                        Grid.Column="0" Grid.Row="0" Margin="4,0,0,4"
                        IsEnabled="{Binding CanRender}"
                        Click="btnRenderTemplate_Click"
                        Background="#FFFDEBC4"/>

                <Button x:Name="btnRenderAllTemplates"
                        Content="Render All Templates"
                        Grid.Column="0" Grid.Row="1" Margin="4,0,0,4"
                        Click="btnRenderAllTemplates_Click"
                        Background="#FFFDEBC4"/>

                <Button x:Name="btnRefresh"
                        Content="Refresh"
                        Grid.Column="0" Grid.Row="2"  Margin="4,0,0,0"
                        Click="btnRefresh_Click"
                        Background="#FFFDEBC4"/>
            </Grid>
                      
            <TextBlock Grid.Column="1" Text="Template:" VerticalAlignment="Center" Margin="8,0,0,0"/>
            <ComboBox Grid.Column="2" Grid.ColumnSpan="2"
                      Margin="4,0,4,0"
                      ItemsSource="{Binding Templates}"
                      SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"/>

            <CheckBox Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" VerticalAlignment="Center" Margin="8,4,0,0"
                      Content="All Entities"
                      ToolTip="Render for every entity in the model."
                      IsChecked="{Binding RenderAllEntities}"/>

            <CheckBox Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="2" VerticalAlignment="Center" Margin="8,0,0,0"
                      Content="Overwrite Existing Files"
                      IsChecked="{Binding OverwriteExisting}"/>

            <CheckBox Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="3" VerticalAlignment="Center" Margin="8,4,0,0"
                      Content="Use Resx Resource"
                      IsChecked="{Binding UseResourceFiles}"/>


            <TextBlock Grid.Column="4" Grid.Row="0" Margin="4,2,0,0"
                       Text="Target Folder:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="5" Grid.ColumnSpan="2" Grid.Row="0"
                     Text="{Binding TargetFolder, Mode=TwoWay}"
                     ToolTip="{Binding TargetDirectory}"
                     Style="{StaticResource textBoxStyle}" Margin="4,0"
                     Background="#FFFFFAED"/>
                     
            <!-- The Contracts Namespace and Repository Namespace are intentionally placed in the middle to align with the Target Folder, as they are more closely related to the infrastructure layer. -->

            <TextBlock Grid.Column="4" Grid.Row="1" Margin="4,2,0,0"
                       Text="Target Infrastructure Folder:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="5" Grid.ColumnSpan="2" Grid.Row="1"
                     Text="{Binding InfrastructureFolder, Mode=TwoWay}"
                     ToolTip="{Binding TargetInfrastructureDirectory}"
                     Style="{StaticResource textBoxStyle}" Margin="4,0"
                     Background="#FFFFFAED"/>
            <TextBlock Grid.Column="4" Grid.Row="2" Margin="4,2,0,0"
                       Text="Infrastructure Namespace:"
                       ToolTip="Namespace for generated infrastructure contracts."
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="5" Grid.Row="2"
                     Text="{Binding ContractsNamespaceName, Mode=TwoWay}"
                     ToolTip="Namespace for generated infrastructure contracts."
                     Style="{StaticResource textBoxStyle}" Margin="4,0"
                     Background="#FFFFFAED"/>
            
            

            <TextBlock Grid.Column="4" Grid.Row="3" Margin="4,2,0,0"
                       Text="Repository Namespace:"
                       ToolTip="Namespace for generated repository."
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="5" Grid.Row="3"
                     Text="{Binding RepositoryNamespaceName, Mode=TwoWay}"
                     ToolTip="Namespace for generated repository."
                     Style="{StaticResource textBoxStyle}" Margin="4,0"
                     Background="#FFFFFAED"/>


            <TextBlock Grid.Column="7" Grid.Row="0" Margin="4,2,0,0"
                       Text="Commands Namespace:"
                       ToolTip="Namespace for generated commands."
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="8" Grid.Row="0"
                     Text="{Binding CommandNamespaceName, Mode=TwoWay}"
                     ToolTip="Namespace for generated commands."
                     Style="{StaticResource textBoxStyle}" Background="#FFFFFAED"/>

            <TextBlock Grid.Column="7" Grid.Row="1" Margin="4,2,0,0"
                       Text="ViewModel Namespace:"
                       ToolTip="Namespace for generated view models."
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="8" Grid.Row="1"
                     Text="{Binding ViewModelNamespaceName, Mode=TwoWay}"
                     ToolTip="Namespace for generated view models."
                     Style="{StaticResource textBoxStyle}" Background="#FFFFFAED"/>

            <TextBlock Grid.Column="7" Grid.Row="2" Margin="4,2,0,0"
                       Text="View Namespace:"
                       ToolTip="Namespace for generated views."
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="8" Grid.Row="2"
                     Text="{Binding ViewNamespaceName, Mode=TwoWay}"
                     ToolTip="Namespace for generated views."
                     Style="{StaticResource textBoxStyle}" Background="#FFFFFAED"/>

            <TextBlock Grid.Column="7" Grid.Row="3" Margin="4,2,0,0"
                       Text="Service Namespace:"
                       ToolTip="Namespace for generated services."
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="8" Grid.Row="3"
                     Text="{Binding ServiceNamespaceName, Mode=TwoWay}"
                     ToolTip="Namespace for generated services."
                     Style="{StaticResource textBoxStyle}" Background="#FFFFFAED"/>

            

            <TextBlock Grid.Column="9" Grid.Row="0" Margin="4,2,0,0"
                       Text="Commands Folder:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="10" Grid.Row="0"
                     Text="{Binding CommandFolder, Mode=TwoWay}"
                     ToolTip="{Binding TargetCommandDirectory}"
                     Style="{StaticResource textBoxStyle}" Background="#FFFFFAED"/>
            <TextBlock Grid.Column="9" Grid.Row="1" Margin="4,2,0,0"
                       Text="ViewModel Folder:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="10" Grid.Row="1"
                     Text="{Binding ViewModelFolder, Mode=TwoWay}"
                     ToolTip="{Binding TargetViewModelDirectory}"
                     Style="{StaticResource textBoxStyle}" Background="#FFFFFAED"/>

            <TextBlock Grid.Column="9" Grid.Row="2" Margin="4,2,0,0"
                       Text="View Folder:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="10" Grid.Row="2"
                     Text="{Binding ViewFolder, Mode=TwoWay}"
                     ToolTip="{Binding TargetViewDirectory}"
                     Style="{StaticResource textBoxStyle}" Background="#FFFFFAED"/>

            <TextBlock Grid.Column="9" Grid.Row="3" Margin="4,2,0,0"
                       Text="Service Folder:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="10" Grid.Row="3"
                     Text="{Binding ServiceFolder, Mode=TwoWay}"
                     ToolTip="{Binding TargetServiceDirectory}"
                     Style="{StaticResource textBoxStyle}" Background="#FFFFFAED"/>


            <Grid Grid.Row="4" Grid.ColumnSpan="11" Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MaxWidth="832"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <DataGrid x:Name="grdEntitySettings" Background="#FFFFE19F"
                          ItemsSource="{Binding Entities, Mode=TwoWay}"
                          SelectedItem="{Binding CurrentEntitySetting, Mode=TwoWay}"
                          CanUserDeleteRows="False"
                          CanUserAddRows="False"
                          AutoGeneratedColumns="grdEntitySettings_AutoGeneratedColumns"
                          AutoGeneratingColumn="grdEntitySettings_AutoGeneratingColumn">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="mnuEntityOptions" Header="Options" IsEnabled="False"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="8" ResizeDirection="Columns"/>

                <Grid Grid.Column="1" Margin="8,0,0,0" Background="#FFFDEBC4"
                      DataContext="{Binding SelectedItem, ElementName=grdEntitySettings}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MaxWidth="320"/>
                        <ColumnDefinition Width="4*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Margin="4,4,0,0"
                               Text="Repository Name:"
                               ToolTip="Name of the repository for the entity"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="0" Grid.Row="1" Margin="4,0,4,0"
                             Text="{Binding RepositoryName, Mode=TwoWay}"
                             ToolTip="Name of the repository for the entity"
                             Style="{StaticResource textBoxStyle}" VerticalAlignment="Top"/>

                    <TextBlock Grid.Column="0" Grid.Row="2"  Margin="4,4,0,0"
                               Text="SubFolder:"
                               ToolTip="SubFolder for the entity, if this is empty or whitespace, generated files will be placed in the related folders."
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="0" Grid.Row="3" Margin="4,0,4,0"
                             Text="{Binding SubFolder, Mode=TwoWay}"
                             ToolTip="SubFolder for the entity, if this is empty or whitespace, generated files will be placed in the related folders."/>

                    <CheckBox Grid.Row="6" VerticalAlignment="Center" Margin="4,0,0,0"
                              Content="Generate Create ViewModel"
                              ToolTip="Generate a Create ViewModel for the entity."
                              IsChecked="{Binding GenerateCreateViewModel}"/>

                    <CheckBox Grid.Row="7" VerticalAlignment="Center" Margin="4,0,0,0"
                              Content="Generate Edit ViewModel"
                              ToolTip="Generate an Edit ViewModel for the entity."
                              IsChecked="{Binding GenerateEditViewModel}"/>

                    <CheckBox Grid.Row="8" VerticalAlignment="Center" Margin="4,0,0,0"
                              Content="Generate Create View"
                              ToolTip="Generate a Create View for the entity."
                              IsChecked="{Binding GenerateCreateView}"/>

                    <CheckBox Grid.Row="9" VerticalAlignment="Center" Margin="4,0,0,0"
                              Content="Generate Edit View"
                              ToolTip="Generate an Edit View for the entity."
                              IsChecked="{Binding GenerateEditView}"/>

                    <CheckBox Grid.Row="10" VerticalAlignment="Center" Margin="4,0,0,0"
                              Content="Generate Lookup Service"
                              IsChecked="{Binding GenerateLookupService}"/>


                    <GridSplitter Grid.Column="1" Grid.RowSpan="16" HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="8" ResizeDirection="Columns"/>
                    <DataGrid x:Name="grdPropertySettings" Grid.Column="1" Grid.RowSpan="16" Margin="8,0,0,0" Background="#FFFDEBC4"
                              ItemsSource="{Binding Properties, Mode=TwoWay}"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              AutoGeneratedColumns="grdPropertySettings_AutoGeneratedColumns"
                              AutoGeneratingColumn="grdEntitySettings_AutoGeneratingColumn">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="mnuPropertyOptions" Header="Options" IsEnabled="False"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</ui:AbstractEngineUI>
