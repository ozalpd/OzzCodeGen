<ui:AbstractEngineUI x:Class="OzzCodeGen.CodeEngines.WpfMvvm.UI.WpfMvvmEngineUI"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:System="clr-namespace:System;assembly=mscorlib"
					 xmlns:Converters="clr-namespace:OzzUtils.Wpf.Converters;assembly=OzzUtils"
                     xmlns:ui="clr-namespace:OzzCodeGen.UI" xmlns:CodeGen="clr-namespace:OzzCodeGen"
                     mc:Ignorable="d"
                     d:DesignHeight="720" d:DesignWidth="1800">
    <UserControl.Resources>
        <ResourceDictionary>
            <Converters:EnumDescriptionConverter x:Key="enumConverter" />
            <Style x:Key="wpfMvvmTextBoxStyle" TargetType="TextBox"
                   BasedOn="{StaticResource textBoxStyle}">
                <Setter Property="Background" Value="#FFFFFAE0" />
                <Setter Property="Margin" Value="0,1,4,1" />
            </Style>
            <Style x:Key="entGridTextBoxStyle" TargetType="TextBox"
                   BasedOn="{StaticResource wpfMvvmTextBoxStyle}">
                <Setter Property="Margin" Value="4,0" />
            </Style>
            <Style x:Key="entGridTextBlockStyle" TargetType="TextBlock">
                <Setter Property="Margin" Value="4,4,0,0" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
            <Style x:Key="entGridCheckBoxStyle" TargetType="CheckBox">
                <Setter Property="Margin" Value="4,0,0,0" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="Background" Value="#FFFFFAA8" />
            </Style>
            <ObjectDataProvider x:Key="generateMode" MethodName="GetValues" ObjectType="{x:Type System:Enum}">
                <ObjectDataProvider.MethodParameters>
                    <x:Type TypeName="CodeGen:FileGenerationMode" />
                </ObjectDataProvider.MethodParameters>
            </ObjectDataProvider>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/OzzCodeGen;component/Resources/BootstrapIcons.xaml" />
                <ResourceDictionary Source="/OzzCodeGen;component/Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border BorderBrush="#FF9090AF" Background="#FFFFE19F" Padding="2" Margin="2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="144" />
                <ColumnDefinition Width="64" />
                <ColumnDefinition Width="96" />
                <ColumnDefinition Width="96" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="176" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="176" />
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="48" />
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="26"/>
                <RowDefinition Height="26"/>
                <RowDefinition Height="26"/>
                <RowDefinition Height="26"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid Grid.RowSpan="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="42"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Button x:Name="btnRenderTemplate"
                        Content="Render Template"
                        Grid.Column="0" Grid.Row="0" Margin="4,0,0,4"
                        IsEnabled="{Binding CanRender}"
                        Click="btnRenderTemplate_Click"
                        Background="#FFFDEBC4"/>

                <Button x:Name="btnRenderAllTemplates"
                        Content="Render All Templates"
                        Grid.Column="0" Grid.Row="1" Margin="4,0,0,4"
                        Click="btnRenderAllTemplates_Click"
                        Background="#FFFDEBC4"/>

                <Button x:Name="btnRefresh"
                        Content="Refresh"
                        Grid.Column="0" Grid.Row="2"  Margin="4,0,0,0"
                        Click="btnRefresh_Click"
                        Background="#FFFDEBC4"/>
            </Grid>

            <TextBlock Grid.Column="1" Text="Template:" VerticalAlignment="Center" Margin="8,0,0,0"/>
            <ComboBox Grid.Column="2" Grid.ColumnSpan="2"
                      Style="{StaticResource comboBoxStyle}"
                      ItemsSource="{Binding Templates}"
                      SelectedItem="{Binding SelectedTemplate, Mode=TwoWay}"/>

            <CheckBox Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1" VerticalAlignment="Center" Margin="8,4,0,0"
                      Content="All Entities"
                      ToolTip="Render for every entity in the model."
                      IsChecked="{Binding RenderAllEntities}"/>

            <CheckBox Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="2" VerticalAlignment="Center" Margin="8,0,0,0"
                      Content="Overwrite Existing Files"
                      IsChecked="{Binding OverwriteExisting}"/>

            <CheckBox Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="3" VerticalAlignment="Center" Margin="8,4,0,0"
                      Content="Use Localized Resx"
                      IsChecked="{Binding UseLocalizedResx}"/>


            <TextBlock Grid.Column="4" Grid.Row="0" Margin="4,2,0,0"
                       Text="Target Folder:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="5" Grid.ColumnSpan="2" Grid.Row="0"
                     Text="{Binding TargetFolder, Mode=TwoWay}"
                     ToolTip="{Binding TargetDirectory}"
                     Style="{StaticResource wpfMvvmTextBoxStyle}"/>


			<TextBlock Grid.Column="4" Grid.Row="1" Margin="4,2,0,0"
                       Text="Namespace Name:"
                       VerticalAlignment="Center"/>
			<TextBox Grid.Column="5" Grid.Row="1"
                     Text="{Binding NamespaceName, Mode=TwoWay}"
                     Style="{StaticResource wpfMvvmTextBoxStyle}"/>


            <TextBlock Grid.Column="4" Grid.Row="2" Margin="4,2,0,0"
                       Text="Target Infrastructure Folder:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="5" Grid.ColumnSpan="2" Grid.Row="2"
                     Text="{Binding InfrastructureFolder, Mode=TwoWay}"
                     ToolTip="{Binding TargetInfrastructureDirectory}"
                     Style="{StaticResource wpfMvvmTextBoxStyle}"/>
            <TextBlock Grid.Column="4" Grid.Row="3" Margin="4,2,0,0"
                       Text="Infrastructure Namespace:"
                       ToolTip="Namespace for generated infrastructure contracts."
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="5" Grid.Row="3"
                     Text="{Binding InfrastructureNamespaceName, Mode=TwoWay}"
                     ToolTip="Namespace for generated infrastructure contracts or base classes."
                     Style="{StaticResource wpfMvvmTextBoxStyle}"/>



            <TextBlock Grid.Column="7" Grid.Row="0" Margin="4,2,0,0"
                       Text="Commands Folder/Namespace:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="8" Grid.Row="0"
                     Text="{Binding CommandFolder, Mode=TwoWay}"
                     ToolTip="{Binding TargetCommandDirectory}"
                     Style="{StaticResource wpfMvvmTextBoxStyle}"/>
            <TextBlock Grid.Column="7" Grid.Row="1" Margin="4,2,0,0"
                       Text="ViewModel Folder/Namespace:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="8" Grid.Row="1"
                     Text="{Binding ViewModelFolder, Mode=TwoWay}"
                     ToolTip="{Binding TargetViewModelDirectory}"
                     Style="{StaticResource wpfMvvmTextBoxStyle}"/>

            <TextBlock Grid.Column="7" Grid.Row="2" Margin="4,2,0,0"
                       Text="View Folder/Namespace:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="8" Grid.Row="2"
                     Text="{Binding ViewFolder, Mode=TwoWay}"
                     ToolTip="{Binding TargetViewDirectory}"
                     Style="{StaticResource wpfMvvmTextBoxStyle}"/>



            <TextBlock Grid.Column="9" Grid.Row="0" Margin="4,2,0,0"
                       Text="Repository Class Namespace:"
                       ToolTip="Namespace for repository implementations."
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="10" Grid.Row="0"
                     Text="{Binding RepositoryNamespaceName, Mode=TwoWay}"
                     ToolTip="Namespace for repository implementations."
                     Style="{StaticResource wpfMvvmTextBoxStyle}"/>

            <TextBlock Grid.Column="9" Grid.Row="1" Margin="4,2,0,0"
                       Text="Repost. Contract Namespace:"
                       ToolTip="Namespace for repository contracts."
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="10" Grid.Row="1"
                     Text="{Binding RepoContractNamespaceName, Mode=TwoWay}"
                     ToolTip="Namespace for repository contracts."
                     Style="{StaticResource wpfMvvmTextBoxStyle}"/>

            <TextBlock Grid.Column="9" Grid.Row="2" Margin="4,2,0,0"
                       Text="XAML Resources Folder:"
                       ToolTip="Folder for XAML resources."
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="10" Grid.Row="2"
                     Text="{Binding XamlResourcesFolder, Mode=TwoWay}"
                     ToolTip="{Binding TargetXamlResourcesDirectory}"
                     Style="{StaticResource wpfMvvmTextBoxStyle}"/>

            <TextBlock Grid.Column="9" Grid.Row="3" Margin="4,2,0,0"
                       Text="Lookup Service Folder:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="10" Grid.Row="3"
                     Text="{Binding LookupFolder, Mode=TwoWay}"
                     ToolTip="{Binding TargetLookupDirectory}"
                     Style="{StaticResource wpfMvvmTextBoxStyle}"/>

            <CheckBox Grid.Column="11" Grid.ColumnSpan="2" Grid.Row="3" VerticalAlignment="Center"
                      Content="Put Lookup in Infrastructure"
                      IsChecked="{Binding PutLookupInInfra}"/>


            <Grid Grid.Row="4" Grid.ColumnSpan="14" Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MaxWidth="1440" MinWidth="240"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <DataGrid x:Name="grdEntitySettings" Background="#FFFFE19F"
                          ItemsSource="{Binding Entities, Mode=TwoWay}"
                          SelectedItem="{Binding CurrentEntitySetting, Mode=TwoWay}"
                          CanUserDeleteRows="False"
                          CanUserAddRows="False"
                          AutoGeneratedColumns="grdEntitySettings_AutoGeneratedColumns"
                          AutoGeneratingColumn="grdEntitySettings_AutoGeneratingColumn">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="mnuEntityOptions" Header="Options" IsEnabled="False"/>
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="8" ResizeDirection="Columns"/>

                <Grid Grid.Column="1" Margin="8,0,0,0" Background="#FFFDEBC4"
                      DataContext="{Binding SelectedItem, ElementName=grdEntitySettings}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*" MinWidth="140" MaxWidth="200"/>
                        <ColumnDefinition Width="6*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="32"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="24"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="SubFolder:"
                               ToolTip="SubFolder for the entity, if this is empty or whitespace, generated files will be placed in the related folders."
                               Style="{StaticResource entGridTextBlockStyle}"/>
                    <TextBox Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding SubFolder, Mode=TwoWay}"
                             ToolTip="SubFolder for the entity, if this is empty or whitespace, generated files will be placed in the related folders."
                             Style="{StaticResource entGridTextBoxStyle}"/>

                    <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="Repository Name:"
                               ToolTip="Name of the repository for the entity"
                               Style="{StaticResource entGridTextBlockStyle}"/>
                    <TextBox Grid.Row="3" Grid.ColumnSpan="2" Text="{Binding RepositoryName, Mode=TwoWay}"
                             ToolTip="Name of the repository for the entity"
                             Style="{StaticResource entGridTextBoxStyle}"/>

                    <TextBlock Grid.Row="4" Grid.ColumnSpan="2" Text="Command ViewModel Type Name:"
                               ToolTip="Name of the command ViewModel for the entity"
                               Style="{StaticResource entGridTextBlockStyle}"/>
                    <TextBox Grid.Row="5" Grid.ColumnSpan="2" Text="{Binding CommandVmTypeName, Mode=TwoWay}"
                             ToolTip="Name of the command ViewModel for the entity"
                             Style="{StaticResource entGridTextBoxStyle}"/>
                    <TextBlock Grid.Row="6" Grid.ColumnSpan="2" Text="Command ViewModel Namespace:"
                               ToolTip="Namespace of the command ViewModel for the entity"
                               Style="{StaticResource entGridTextBlockStyle}"/>
                    <TextBox Grid.Row="7" Grid.ColumnSpan="2" Text="{Binding CommandVmNamespace, Mode=TwoWay}"
                             ToolTip="Namespace of the command ViewModel for the entity"
                             Style="{StaticResource entGridTextBoxStyle}"/>


                    <TextBlock Grid.Row="9" Text="Create Command"
                               ToolTip="Generate Mode for Create Command for the entity."
                               Style="{StaticResource rightAlignedTextBlockStyle}"/>
                    <ComboBox Grid.Column="1" Grid.Row="9" Style="{StaticResource comboBoxStyle}"
                              ItemsSource="{Binding Source={StaticResource generateMode}}"
                              SelectedItem="{Binding GenModeCreateCommand}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource enumConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Grid.Row="10" Text="Edit Command"
                               ToolTip="Generate Mode forn Edit Command for the entity."
                               Style="{StaticResource rightAlignedTextBlockStyle}"/>
                    <ComboBox Grid.Column="1" Grid.Row="10" Style="{StaticResource comboBoxStyle}"
                              ItemsSource="{Binding Source={StaticResource generateMode}}"
                              SelectedItem="{Binding GenModeEditCommand}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource enumConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Grid.Row="11" Text="Delete Command"
                               ToolTip="Generate Mode for Delete Command for the entity."
                               Style="{StaticResource rightAlignedTextBlockStyle}"/>
                    <ComboBox Grid.Column="1" Grid.Row="11" Style="{StaticResource comboBoxStyle}"
                              ItemsSource="{Binding Source={StaticResource generateMode}}"
                              SelectedItem="{Binding GenModeDeleteCommand}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource enumConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Grid.Row="13" Text="Create VM"
                               ToolTip="Generate Mode for Create ViewModel for the entity."
                               Style="{StaticResource rightAlignedTextBlockStyle}"/>
                    <ComboBox Grid.Column="1" Grid.Row="13" Style="{StaticResource comboBoxStyle}"
                              ItemsSource="{Binding Source={StaticResource generateMode}}"
                              SelectedItem="{Binding GenModeCreateVM}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource enumConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Grid.Row="14" Text="Edit VM"
                               ToolTip="Generate Mode for Edit ViewModel for the entity."
                               Style="{StaticResource rightAlignedTextBlockStyle}"/>
                    <ComboBox Grid.Column="1" Grid.Row="14" Style="{StaticResource comboBoxStyle}"
                              ItemsSource="{Binding Source={StaticResource generateMode}}"
                              SelectedItem="{Binding GenModeEditVM}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource enumConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Grid.Row="15" Text="Collection VM:"
                               ToolTip="Generate Mode for Collection ViewModel for the entity."
                               Style="{StaticResource rightAlignedTextBlockStyle}"/>
                    <ComboBox Grid.Column="1" Grid.Row="15" Style="{StaticResource comboBoxStyle}"
                              ItemsSource="{Binding Source={StaticResource generateMode}}"
                              SelectedItem="{Binding GenModeCollectionVM}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource enumConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Grid.Row="17" Text="Create View"
                               ToolTip="Generate Mode for Create View for the entity."
                               Style="{StaticResource rightAlignedTextBlockStyle}"/>
                    <ComboBox Grid.Column="1" Grid.Row="17" Style="{StaticResource comboBoxStyle}"
                              ItemsSource="{Binding Source={StaticResource generateMode}}"
                              SelectedItem="{Binding GenModeCreateView}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource enumConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Grid.Row="18" Text="Edit View"
                               ToolTip="Generate Mode for Edit View for the entity."
                               Style="{StaticResource rightAlignedTextBlockStyle}"/>
                    <ComboBox Grid.Column="1" Grid.Row="18" Style="{StaticResource comboBoxStyle}"
                              ItemsSource="{Binding Source={StaticResource generateMode}}"
                              SelectedItem="{Binding GenModeEditView}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource enumConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Grid.Row="20" Text="Lookup Service"
                               ToolTip="Generate Mode for Lookup Service for the entity."
                               Style="{StaticResource rightAlignedTextBlockStyle}"/>
                    <ComboBox Grid.Column="1" Grid.Row="20" Margin="4,0"
                              ItemsSource="{Binding Source={StaticResource generateMode}}"
                              SelectedItem="{Binding GenModeLookupService}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource enumConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>


                    <GridSplitter Grid.Column="2" Grid.RowSpan="26" HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="8" ResizeDirection="Columns"/>
                    <DataGrid x:Name="grdPropertySettings" Grid.Column="2" Grid.RowSpan="26" Margin="8,0,0,0" Background="#FFFDEBC4"
                              ItemsSource="{Binding Properties, Mode=TwoWay}"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              AutoGeneratedColumns="grdPropertySettings_AutoGeneratedColumns"
                              AutoGeneratingColumn="grdEntitySettings_AutoGeneratingColumn">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="mnuPropertyOptions" Header="Options" IsEnabled="False"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</ui:AbstractEngineUI>
