<ui:AbstractEngineUI x:Class="OzzCodeGen.CodeEngines.CsSqliteRepository.UI.SqliteRepositoryEngineUI"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:ui="clr-namespace:OzzCodeGen.UI"
                     mc:Ignorable="d"
                     d:DesignHeight="460" d:DesignWidth="1400">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/OzzCodeGen;component/Resources/BootstrapIcons.xaml" />
                <ResourceDictionary Source="/OzzCodeGen;component/Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Border BorderBrush="#FF89A4AF" Padding="2" Margin="2">
        <Grid Background="#FFE6F7FA">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="160" MinWidth="80"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="10*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button x:Name="btnRenderTemplate"
                    Content="Render Template"
                    Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Margin="4,4,0,2"
                    Click="btnRenderTemplate_Click"/>

            <Button x:Name="btnRefresh"
                    Content="Refresh"
                    Grid.Column="0" Grid.Row="2" Grid.RowSpan="2" Margin="4,4,0,2"
                    Click="btnRefresh_Click"/>

            <CheckBox Content="All Entities"
                      IsChecked="{Binding RenderAllEntities}"
                      ToolTip="Render for every entity in the model."
                      Grid.Column="1" VerticalAlignment="Center" Margin="8,4,0,0"/>

            <CheckBox Grid.Column="1" Grid.Row="1" VerticalAlignment="Center" Margin="8,0,0,0"
                      Content="Overwrite Existing Files"
                      IsChecked="{Binding OverwriteExisting}"/>

            <CheckBox Grid.Column="1" Grid.Row="2" VerticalAlignment="Center" Margin="8,4,0,0"
                      Content="Generate Base Repository"
                      ToolTip="Generate the shared SQLite repository base class file."
                      IsChecked="{Binding GenerateBaseRepository}"/>

            <TextBlock Grid.Column="2" Grid.Row="0" Margin="4,2,0,0"
                       Text="Repository Namespace:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="3" Grid.Row="0"
                     Text="{Binding NamespaceName, Mode=TwoWay}"
                     Style="{StaticResource textBoxStyle}"/>

            <TextBlock Grid.Column="2" Grid.Row="1" Margin="4,2,0,0"
                       Text="Model Namespace:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="3" Grid.Row="1"
                     Text="{Binding ModelNamespaceName, Mode=TwoWay}"
                     Style="{StaticResource textBoxStyle}"/>

            <TextBlock Grid.Column="2" Grid.Row="2" Margin="4,2,0,0"
                       Text="Base Class Name:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="3" Grid.Row="2"
                     Text="{Binding BaseRepositoryClassName, Mode=TwoWay}"
                     Style="{StaticResource textBoxStyle}"/>

            <TextBlock Grid.Column="4" Grid.Row="0" Margin="4,2,0,0"
                       Text="Target Folder:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="5" Grid.Row="0"
                     Text="{Binding TargetFolder, Mode=TwoWay}"
                     ToolTip="{Binding TargetDirectory}"
                     Style="{StaticResource textBoxStyle}"/>

            <Grid Grid.Row="4" Grid.ColumnSpan="6" Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MaxWidth="360"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <DataGrid x:Name="grdEntitySettings" ItemsSource="{Binding Entities, Mode=TwoWay}"
                          SelectedItem="{Binding CurrentEntitySetting, Mode=TwoWay}"
                          AutoGeneratedColumns="grdEntitySettings_AutoGeneratedColumns"
                          CanUserDeleteRows="False"
                          CanUserAddRows="False"
                          AutoGeneratingColumn="grdEntitySettings_AutoGeneratingColumn">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="mnuEntityOptions" Header="Options" IsEnabled="False" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="8" ResizeDirection="Columns" />

                <Grid Grid.Column="2" Margin="8,0,0,0"
                      DataContext="{Binding SelectedItem, ElementName=grdEntitySettings}">
                    <DataGrid x:Name="grdPropertySettings"
                              ItemsSource="{Binding Properties, Mode=TwoWay}"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              AutoGeneratedColumns="grdPropertySettings_AutoGeneratedColumns"
                              AutoGeneratingColumn="grdEntitySettings_AutoGeneratingColumn">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="mnuPropertyOptions" Header="Options" IsEnabled="False" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CLR Type" Width="110" Binding="{Binding ClrTypeName}" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</ui:AbstractEngineUI>
