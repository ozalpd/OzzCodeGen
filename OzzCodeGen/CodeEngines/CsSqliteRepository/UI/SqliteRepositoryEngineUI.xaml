<ui:AbstractEngineUI x:Class="OzzCodeGen.CodeEngines.CsSqliteRepository.UI.SqliteRepositoryEngineUI"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:ui="clr-namespace:OzzCodeGen.UI"
                     mc:Ignorable="d"
                     d:DesignHeight="460" d:DesignWidth="1420">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/OzzCodeGen;component/Resources/BootstrapIcons.xaml" />
                <ResourceDictionary Source="/OzzCodeGen;component/Resources/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Border BorderBrush="#FF041C24" Padding="2">
        <Grid Background="#FFE6F7FA">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="144"/>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="160" />
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button x:Name="btnRenderTemplate"
                    Content="Render Template"
                    Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Margin="4,4,0,2"
                    Click="btnRenderTemplate_Click"/>

            <Button x:Name="btnRefresh"
                    Content="Refresh"
                    Grid.Column="0" Grid.Row="2" Grid.RowSpan="2" Margin="4,4,0,2"
                    Click="btnRefresh_Click"/>

            <CheckBox Content="All Entities"
                      IsChecked="{Binding RenderAllEntities}"
                      ToolTip="Render for every entity in the model."
                      Grid.Column="1" VerticalAlignment="Center" Margin="8,4,0,0"/>

            <CheckBox Grid.Column="1" Grid.Row="1" VerticalAlignment="Center" Margin="8,0,0,0"
                      Content="Overwrite Existing Files"
                      IsChecked="{Binding OverwriteExisting}"/>

            <TextBlock Grid.Column="2" Grid.Row="0" Margin="4,2,0,0"
                       Text="Repository Namespace:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="3" Grid.Row="0"
                     Text="{Binding NamespaceName, Mode=TwoWay}"
                     Style="{StaticResource textBoxStyle}"/>

            <TextBlock Grid.Column="2" Grid.Row="1" Margin="4,2,0,0"
                       Text="Base Class Name:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="3" Grid.Row="1"
                     Text="{Binding BaseRepositoryClassName, Mode=TwoWay}"
                     Style="{StaticResource textBoxStyle}"/>

            <TextBlock Grid.Column="4" Grid.Row="0" Margin="4,2,0,0"
                       Text="Target Folder:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="5" Grid.ColumnSpan="3" Grid.Row="0"
                     Text="{Binding TargetFolder, Mode=TwoWay}"
                     ToolTip="{Binding TargetDirectory}"
                     Style="{StaticResource textBoxStyle}"/>

            <TextBlock Grid.Column="4" Grid.Row="1" Margin="4,2,0,0"
                       Text="Metadata Repository Name:"
                       VerticalAlignment="Center"/>
            <TextBox Grid.Column="5" Grid.Row="1"
                     Text="{Binding MetadataRepositoryName, Mode=TwoWay}"
                     Style="{StaticResource textBoxStyle}"/>

            <Grid Grid.Row="4" Grid.ColumnSpan="10" Margin="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MaxWidth="860"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <DataGrid x:Name="grdEntitySettings" Background="#FFE6F7FA"
                          ItemsSource="{Binding Entities, Mode=TwoWay}"
                          SelectedItem="{Binding CurrentEntitySetting, Mode=TwoWay}"
                          AutoGeneratedColumns="grdEntitySettings_AutoGeneratedColumns"
                          CanUserDeleteRows="False"
                          CanUserAddRows="False"
                          AutoGeneratingColumn="grdEntitySettings_AutoGeneratingColumn">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem x:Name="mnuEntityOptions" Header="Options" IsEnabled="False" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>

                <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="6" ResizeDirection="Columns" />

                <Grid Grid.Column="2" Margin="0"
                      DataContext="{Binding SelectedItem, ElementName=grdEntitySettings}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="3*" MinWidth="120"/>
                        <ColumnDefinition Width="6"/>
                        <ColumnDefinition Width="5*" MinWidth="220"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Column="0" Margin="4,0,0,0"
                               Text="DDL File Name:"
                               ToolTip="Table definition file for initializing the table for entity"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Grid.Row="0"
                             Text="{Binding FileNameDDL, Mode=TwoWay}"
                             ToolTip="Table definition file for initializing the table for entity"
                             Style="{StaticResource textBoxStyle}" VerticalAlignment="Top"/>

                    <TextBlock Grid.Column="0" Grid.Row="1" Margin="4,0,0,0"
                               Text="Seed File Name:"
                               ToolTip="File name for data seed after initializing the table"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Grid.Row="1"
                             Text="{Binding FileNameSeed, Mode=TwoWay}"
                             ToolTip="File name for data seed after initializing the table"
                             Style="{StaticResource textBoxStyle}" VerticalAlignment="Top"/>


                    <TextBlock Grid.Column="0" Grid.Row="2" Margin="4,0,0,0"
                               Text="Overwrite Existing Files:"
                               ToolTip="Overwrite existing files of this entitywhen generating code"
                               VerticalAlignment="Center"/>
                    <CheckBox Grid.Column="1" Grid.Row="2" VerticalAlignment="Center" Margin="0"
                              ToolTip="Overwrite existing files of this entitywhen generating code"
                              IsChecked="{Binding OverwriteExisting}"/>


                    <TextBlock Grid.Column="0" Grid.Row="4" Margin="4,0,0,0"
                               Text="Order By Clause:"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Grid.Row="4"
                             Text="{Binding OrderByClause, Mode=TwoWay}"
                             Style="{StaticResource textBoxStyle}" VerticalAlignment="Top"/>

                    <TextBlock Grid.Column="0" Grid.Row="5" Margin="4,0,0,0"
                               Text="Created at Property Name:"
                               ToolTip="Property name for creation time of the entity"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Grid.Row="5"
                             Text="{Binding CreatedAtName, Mode=TwoWay}"
                             ToolTip="Property name for creation time of the entity"
                             Style="{StaticResource textBoxStyle}" VerticalAlignment="Top"/>

                    <TextBlock Grid.Column="0" Grid.Row="6" Margin="4,0,0,0"
                               Text="Updated at Property Name:"
                               ToolTip="Property name for update time of the entity"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Grid.Row="6"
                             Text="{Binding UpdatedAtName, Mode=TwoWay}"
                             ToolTip="Property name for update time of the entity"
                             Style="{StaticResource textBoxStyle}" VerticalAlignment="Top"/>

                    <GridSplitter Grid.Column="2" Grid.RowSpan="10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Width="6" ResizeDirection="Columns" />
                    <Grid Grid.Column="3" Grid.RowSpan="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>
                        <DataGrid x:Name="grdPropertySettings" Background="#FFFFF8F4"
                                  ItemsSource="{Binding Properties, Mode=TwoWay}"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  AutoGeneratedColumns="grdPropertySettings_AutoGeneratedColumns"
                                  AutoGeneratingColumn="grdEntitySettings_AutoGeneratingColumn">
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem x:Name="mnuPropertyOptions" Header="Options" IsEnabled="False" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="CLR Type" Width="110" Binding="{Binding ClrTypeName}" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border Grid.Column="2" BorderBrush="#FF041C24" Padding="2" BorderThickness="1,1,1,1">
                            <Grid Background="#FFFFF8F4"
                                  DataContext="{Binding SelectedItem, ElementName=grdPropertySettings}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="28"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <CheckBox Grid.Row="0" VerticalAlignment="Center"
                                          ToolTip="Automatically load this property when its parent entity is loaded"
                                          Content="Auto Load"
                                          IsChecked="{Binding AutoLoad}"/>

                                <CheckBox Grid.Row="1" VerticalAlignment="Center"
                                          ToolTip="In update method, check if the value has been altered"
                                          Content="Check If Altered"
                                          IsChecked="{Binding CheckIfAltered}"/>

                                <CheckBox Grid.Row="2" VerticalAlignment="Center"
                                          ToolTip="Generate a dedicated update method for this column"
                                          Content="Single Column Update"
                                          IsChecked="{Binding SingleColumnUpdate}"/>

                                <CheckBox Grid.Row="4" VerticalAlignment="Center"
                                          ToolTip="Indicates if this property is a repository column"
                                          Content="Repository Column"
                                          IsEnabled="False"
                                          IsChecked="{Binding IsRepositoryColumn, Mode=OneWay}"/>

                                <CheckBox Grid.Row="5" VerticalAlignment="Center"
                                          ToolTip="Indicates if this property is uniquely indexed"
                                          Content="Unique Indexed"
                                          IsEnabled="False"
                                          IsChecked="{Binding IsUniqueIndexed, Mode=OneWay}"/>

                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</ui:AbstractEngineUI>
