<#+    }
    if (hasSelfAutoload) { #>
            var <#= EntitySetting.Name.Pluralize().ToCamelCase() #>By<#= pkey.Name #> = (await GetAllAsync()).ToDictionary(item => item.<#= pkey.Name #>);
<#+    } #>
